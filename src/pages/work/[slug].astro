---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient } from "../../lib/sanity";
import { toHTML } from "@portabletext/to-html";

export async function getStaticPaths() {
  const projects = await sanityClient.fetch(`
    *[_type == "project"] {
      slug
    }
  `);

  return projects.map((project: any) => ({
    params: { slug: project.slug.current },
  }));
}

const { slug } = Astro.params;

const project = await sanityClient.fetch(`
  *[_type == "project" && slug.current == $slug][0] {
    title,
    category,
    client,
    publishedAt,
    excerpt,
    tags,
    body
  }
`, { slug });

if (!project) return Astro.redirect("/404");

function formatDate(dateStr: string) {
  if (!dateStr) return "";
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
  });
}

const bodyHTML = project.body ? toHTML(project.body, {
  components: {
    types: {
      code: ({ value }: any) => `<pre><code class="language-${value.language}">${value.code}</code></pre>`,
      image: ({ value }: any) => `<img src="${value.asset?.url ?? ""}" alt="${value.alt ?? ""}" />`,
    },
  },
}) : "";
---

<BaseLayout title={`${project.title} | Visoft`} description={project.excerpt}>
  <section class="hero hero--sub">
    <div class="wrap">
      <a class="back-link" href="/work">← Back to work</a>
      <div class="project-meta">
        {project.category && <span class="project-category">{project.category}</span>}
        {project.client && <span class="project-client">{project.client}</span>}
        {project.publishedAt && <span class="project-date">{formatDate(project.publishedAt)}</span>}
      </div>
      <h1>{project.title}</h1>
      {project.excerpt && <p class="lede">{project.excerpt}</p>}
      {project.tags && project.tags.length > 0 && (
        <div class="tags">
          {project.tags.map((tag: string) => <span>{tag}</span>)}
        </div>
      )}
    </div>
  </section>

  <section class="doc">
    <div class="wrap">
      <div class="section-ref">§ 01</div>
      <div class="section-body project-body" set:html={bodyHTML} />
    </div>
  </section>
</BaseLayout>

<style>
  .hero--sub{
    padding: 72px 0 56px;
    border-bottom: 1px solid var(--rule);
  }
  .hero--sub .wrap{ max-width: 780px; }
  .hero--sub h1{ font-size: var(--fs-h1); margin: 14px 0 20px; }
  .hero--sub .lede{ font-size: 1.12rem; color: var(--muted); max-width: 62ch; margin: 0 0 20px; }

  .back-link{
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    display: inline-block;
  }
  .back-link:hover{ color: var(--chalk); }

  .project-meta{
    display: flex;
    gap: 14px;
    align-items: center;
    margin-top: 18px;
  }
  .project-category{
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--seal-text);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .project-client{
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--verified-text);
    letter-spacing: 0.04em;
  }
  .project-date{
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .tags{ display:flex; flex-wrap:wrap; gap: 8px; }
  .tags span{
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--verified-text);
    border: 1px solid var(--rule);
    padding: 3px 9px;
  }

  .project-body{
    max-width: 68ch;
    color: var(--chalk);
  }
  .project-body :global(p){
    margin: 0 0 20px;
    color: var(--chalk);
  }
  .project-body :global(h2){
    font-size: var(--fs-h2);
    margin: 40px 0 16px;
  }
  .project-body :global(h3){
    font-size: 1.2rem;
    margin: 32px 0 14px;
  }
  .project-body :global(a){ color: var(--seal-text); }
  .project-body :global(ul), .project-body :global(ol){
    margin: 0 0 20px;
    padding-left: 1.4em;
    color: var(--chalk);
  }
  .project-body :global(li){ margin-bottom: 8px; }
  .project-body :global(blockquote){
    margin: 24px 0;
    padding: 4px 20px;
    border-left: 2px solid var(--seal-text);
    color: var(--muted);
  }
  .project-body :global(img){
    max-width: 100%;
    border: 1px solid var(--rule);
    margin: 24px 0;
  }
  .project-body :global(pre){
    background: var(--panel);
    border: 1px solid var(--rule);
    padding: 18px 20px;
    overflow-x: auto;
    margin: 24px 0;
    font-size: 0.88rem;
  }
  .project-body :global(code){
    font-family: var(--mono);
  }
  .project-body :global(pre code){
    color: var(--verified-text);
  }
  .project-body :global(:not(pre) > code){
    background: var(--panel);
    border: 1px solid var(--rule);
    padding: 2px 6px;
    font-size: 0.92em;
  }
</style>
