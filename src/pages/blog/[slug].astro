---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient } from "../../lib/sanity";
import { toHTML } from "@portabletext/to-html";

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`
    *[_type == "blogPost"] {
      slug
    }
  `);

  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;

const post = await sanityClient.fetch(`
  *[_type == "blogPost" && slug.current == $slug][0] {
    title,
    publishedAt,
    excerpt,
    body
  }
`, { slug });

if (!post) return Astro.redirect("/404");

function formatDate(dateStr: string) {
  if (!dateStr) return "";
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

const bodyHTML = post.body ? toHTML(post.body, {
  components: {
    types: {
      code: ({ value }: any) => `<pre><code class="language-${value.language}">${value.code}</code></pre>`,
      image: ({ value }: any) => `<img src="${value.asset?.url ?? ""}" alt="${value.alt ?? ""}" />`,
    },
  },
}) : "";
---

<BaseLayout title={`${post.title} | Visoft`} description={post.excerpt}>
  <section class="hero hero--sub">
    <div class="wrap">
      <a class="back-link" href="/blog">← Back to blog</a>
      {post.publishedAt && <span class="post-date">{formatDate(post.publishedAt)}</span>}
      <h1>{post.title}</h1>
      {post.excerpt && <p class="lede">{post.excerpt}</p>}
    </div>
  </section>

  <section class="doc">
    <div class="wrap">
      <div class="section-ref">§ 01</div>
      <div class="section-body post-body" set:html={bodyHTML} />
    </div>
  </section>
</BaseLayout>

<style>
  .hero--sub{
    padding: 72px 0 56px;
    border-bottom: 1px solid var(--rule);
  }
  .hero--sub .wrap{ max-width: 780px; }
  .hero--sub h1{ font-size: var(--fs-h1); margin: 14px 0 20px; }
  .hero--sub .lede{ font-size: 1.12rem; color: var(--muted); max-width: 62ch; margin: 0; }

  .back-link{
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    display: inline-block;
  }
  .back-link:hover{ color: var(--chalk); }

  .post-date{
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    display: block;
    margin-top: 18px;
  }

  .post-body{
    max-width: 68ch;
    color: var(--chalk);
  }
  .post-body :global(p){
    margin: 0 0 20px;
    color: var(--chalk);
  }
  .post-body :global(h2){
    font-size: var(--fs-h2);
    margin: 40px 0 16px;
  }
  .post-body :global(h3){
    font-size: 1.2rem;
    margin: 32px 0 14px;
  }
  .post-body :global(a){ color: var(--seal-text); }
  .post-body :global(ul), .post-body :global(ol){
    margin: 0 0 20px;
    padding-left: 1.4em;
    color: var(--chalk);
  }
  .post-body :global(li){ margin-bottom: 8px; }
  .post-body :global(blockquote){
    margin: 24px 0;
    padding: 4px 20px;
    border-left: 2px solid var(--seal-text);
    color: var(--muted);
  }
  .post-body :global(img){
    max-width: 100%;
    border: 1px solid var(--rule);
    margin: 24px 0;
  }
  .post-body :global(pre){
    background: var(--panel);
    border: 1px solid var(--rule);
    padding: 18px 20px;
    overflow-x: auto;
    margin: 24px 0;
    font-size: 0.88rem;
  }
  .post-body :global(code){
    font-family: var(--mono);
  }
  .post-body :global(pre code){
    color: var(--verified-text);
  }
  .post-body :global(:not(pre) > code){
    background: var(--panel);
    border: 1px solid var(--rule);
    padding: 2px 6px;
    font-size: 0.92em;
  }
</style>
