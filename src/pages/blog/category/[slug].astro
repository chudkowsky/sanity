---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { sanityClient } from "../../../lib/sanity";

export async function getStaticPaths() {
	function tagSlug(tag: string) {
		return tag.toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
	}

	const posts = await sanityClient.fetch(`
		*[_type == "blogPost" && defined(tags)] { tags }
	`);

	const slugs = new Map<string, string>();
	for (const post of posts) {
		for (const tag of post.tags ?? []) {
			slugs.set(tagSlug(tag), tag);
		}
	}

	return Array.from(slugs.entries()).map(([slug, tag]) => ({
		params: { slug },
		props: { tag },
	}));
}

const { slug } = Astro.params;
const { tag } = Astro.props;

const posts = await sanityClient.fetch(`
	*[_type == "blogPost" && $tag in tags] | order(publishedAt desc) {
		title,
		slug,
		publishedAt,
		excerpt,
		tags,
		"coverImageUrl": coverImage.asset->url
	}
`, { tag });

function formatDate(dateStr: string) {
	if (!dateStr) return "";
	return new Date(dateStr).toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
}
---

<BaseLayout
	title={`${tag} | Visoft Blog`}
	description={`Posts on ${tag} from the Visoft team.`}
>
	<section class="hero hero--sub">
		<div class="wrap">
			<a class="back-link" href="/blog">← Back to blog</a>
			<span class="eyebrow">Category</span>
			<h1>{tag}</h1>
		</div>
	</section>

	<section class="doc">
		<div class="wrap">
			<div class="section-ref">§ 01</div>
			<div class="section-body">
				{posts.length === 0 && <p class="empty">No posts tagged {tag} yet.</p>}
				<div class="post-grid">
					{posts.map((post: any) => (
						<a class="post-card" href={`/blog/${post.slug.current}`}>
							<div class="post-thumb">
								{post.coverImageUrl
									? <img src={post.coverImageUrl} alt="" loading="lazy" />
									: <div class="post-thumb-fallback" aria-hidden="true"></div>
								}
							</div>
							<div class="post-card-body">
								{post.publishedAt && <span class="post-date">{formatDate(post.publishedAt)}</span>}
								<h3>{post.title}</h3>
								{post.excerpt && <p>{post.excerpt}</p>}
							</div>
						</a>
					))}
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.hero--sub{
		padding: 72px 0 56px;
		border-bottom: 1px solid var(--rule);
	}
	.hero--sub .wrap{ max-width: 780px; }
	.hero--sub .eyebrow{ margin: 14px 0 10px; display:block; }
	.hero--sub h1{ font-size: var(--fs-h1); margin: 0; text-transform: capitalize; }

	.back-link{
		font-family: var(--mono);
		font-size: 0.85rem;
		color: var(--muted);
		text-decoration: none;
		display: inline-block;
	}
	.back-link:hover{ color: var(--chalk); }

	.empty{ color: var(--muted); }

	.post-grid{
		display: grid;
		grid-template-columns: repeat(2, minmax(0,1fr));
		gap: 24px;
	}
	@media (max-width: 700px){
		.post-grid{ grid-template-columns: 1fr; }
	}

	.post-card{
		display: flex;
		flex-direction: column;
		background: var(--panel);
		border: 1px solid var(--rule);
		text-decoration: none;
		color: inherit;
	}
	.post-card:hover{ background: var(--panel-2); border-color: var(--seal-text); }
	.post-card:hover h3{ color: var(--seal-text); }

	.post-thumb{
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-bottom: 1px solid var(--rule);
	}
	.post-thumb img{
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.post-thumb-fallback{
		width: 100%;
		height: 100%;
		background-color: var(--ink);
		background-image:
			linear-gradient(rgba(232,228,217,0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(232,228,217,0.045) 1px, transparent 1px);
		background-size: 22px 22px;
		position: relative;
	}
	.post-thumb-fallback::after{
		content: "VI·SOFT";
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.16em;
		color: var(--seal-text);
		opacity: 0.55;
	}

	.post-card-body{
		padding: 22px 24px 26px;
		flex: 1;
	}

	.post-date{
		font-family: var(--mono);
		font-size: 0.78rem;
		color: var(--muted);
		letter-spacing: 0.04em;
		display: block;
		margin-bottom: 8px;
	}
	.post-card h3{
		font-size: 1.2rem;
		margin-bottom: 8px;
	}
	.post-card p{
		color: var(--muted);
		font-size: var(--fs-small);
		margin: 0;
	}
</style>
